---
import BackToTop from '../../components/BackToTop.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import HeaderNav from '../../components/HeaderNav.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getPublishedPosts, getTagStats, getTagUrl } from '../../lib/posts';

export async function getStaticPaths({ paginate }) {
  const posts = await getPublishedPosts();

  return paginate(posts, {
    pageSize: 10
  });
}

const { page } = Astro.props;
const visiblePosts = page.data;
const allPosts = await getPublishedPosts();
const totalPosts = page.total ?? allPosts.length;
const tagStats = getTagStats(allPosts);
const topTags = tagStats.slice(0, 5);
const currentMonth = new Date();
const calendarYear = currentMonth.getFullYear();
const calendarMonth = currentMonth.getMonth();
const calendarMonthName = new Intl.DateTimeFormat('en', { month: 'long' }).format(currentMonth);
const daysInMonth = new Date(calendarYear, calendarMonth + 1, 0).getDate();
const firstDayOffset = (new Date(calendarYear, calendarMonth, 1).getDay() + 6) % 7;
const weekdayLabels = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];
const postsByDay = new Map<number, number>();

for (const post of allPosts) {
  const published = post.data.published;

  if (published.getFullYear() === calendarYear && published.getMonth() === calendarMonth) {
    const day = published.getDate();
    postsByDay.set(day, (postsByDay.get(day) ?? 0) + 1);
  }
}

const maxDailyPosts = Math.max(0, ...postsByDay.values());
const calendarDays = Array.from({ length: daysInMonth }, (_, index) => {
  const day = index + 1;
  const count = postsByDay.get(day) ?? 0;
  const heat = count === 0 || maxDailyPosts === 0 ? 0 : Math.max(1, Math.ceil((count / maxDailyPosts) * 4));

  return { day, count, heat };
});
const currentMonthPostCount = Array.from(postsByDay.values()).reduce((total, count) => total + count, 0);
---
<SiteLayout
  title="Blog | Caiwei Wang"
  description="Research notes and personal academic updates from Caiwei Wang."
  bodyClass="blog-page firefly-blog"
>
  <HeaderNav active="blog" />

  <main id="main" class="prism-main blog-main firefly-blog-main">
    <aside class="firefly-sidebar firefly-left-rail" aria-label="Blog profile">
      <section class="firefly-panel firefly-profile-widget">
        <img src="/images/pic08.png" alt="Blog mascot" />
        <h1>Caiwei's Notes</h1>
        <p>Research logs, reading notes, and small technical experiments.</p>
        <div class="firefly-socials">
          <a href="mailto:wanghz23826@email.com" class="icon solid fa-envelope"><span class="label">Email</span></a>
          <a href="https://github.com/" class="icon brands fa-github"><span class="label">GitHub</span></a>
          <a href="/" class="icon solid fa-home"><span class="label">Home</span></a>
        </div>
      </section>

      <section class="firefly-panel firefly-note-widget">
        <p class="section-kicker">Notice</p>
        <h2>About This Space</h2>
        <p>This blog is a lighter side room for ideas before they become papers, projects, or polished portfolio entries.</p>
        <a href="/#research" class="read-more">View research</a>
      </section>

      <section class="firefly-panel firefly-category-widget">
        <p class="section-kicker">Tags</p>
        <nav class="firefly-tag-list" aria-label="Blog tags">
          {tagStats.length > 0 ? (
            tagStats.map((tag) => (
              <a href={getTagUrl(tag.name)}>
                <span>#{tag.name}</span>
                <strong>{tag.count}</strong>
              </a>
            ))
          ) : (
            <span class="firefly-empty-note">No tags yet</span>
          )}
        </nav>
      </section>
    </aside>

    <section class="firefly-feed" aria-label="Blog posts">
      <div class="firefly-tabs">
        <a href="/blog/" class="firefly-tab-home icon solid fa-home"><span class="label">Blog Home</span></a>
        <a href="/blog/" class="active">All <span>{totalPosts}</span></a>
        {topTags.map((tag) => (
          <a href={getTagUrl(tag.name)}>#{tag.name} <span>{tag.count}</span></a>
        ))}
      </div>

      <section class="firefly-panel firefly-hero-card">
        <p class="section-kicker">Blog</p>
        <h1>Research Notes & Field Logs</h1>
        <p>Independent writing space for project notes, paper reflections, learning logs, and small experiments.</p>
      </section>

      {visiblePosts.length > 0 ? (
        <div class="blog-list firefly-post-list">
          {visiblePosts.map((post) => <BlogPostCard post={post} />)}
        </div>
      ) : (
        <section class="firefly-panel">
          <p>No published posts yet.</p>
        </section>
      )}

      {(page.url.prev || page.url.next) && (
        <nav class="blog-pagination" aria-label="Blog pagination">
          {page.url.prev ? <a href={page.url.prev}>Newer Posts</a> : <span />}
          <span>Page {page.currentPage} of {page.lastPage}</span>
          {page.url.next ? <a href={page.url.next}>Older Posts</a> : <span />}
        </nav>
      )}
    </section>

    <aside class="firefly-sidebar firefly-right-rail" aria-label="Blog widgets">
      <section class="firefly-panel firefly-stats-widget">
        <p class="section-kicker">Statistics</p>
        <dl>
          <div><dt>Posts</dt><dd>{totalPosts}</dd></div>
          <div><dt>Tags</dt><dd>{tagStats.length}</dd></div>
          <div><dt>This Month</dt><dd>{currentMonthPostCount}</dd></div>
          <div><dt>Status</dt><dd>Online</dd></div>
        </dl>
      </section>

      <section class="firefly-panel firefly-info-widget">
        <p class="section-kicker">Site Info</p>
        <dl>
          <div><dt>Platform</dt><dd>Astro</dd></div>
          <div><dt>Source</dt><dd>Markdown + Notion</dd></div>
          <div><dt>Style</dt><dd>Firefly-like</dd></div>
        </dl>
      </section>

      <section class="firefly-panel firefly-calendar-widget">
        <div class="firefly-calendar-head">
          <span>{calendarYear}</span>
          <strong>{calendarMonthName}</strong>
        </div>
        <div class="firefly-calendar-weekdays" aria-hidden="true">
          {weekdayLabels.map((day) => <span>{day}</span>)}
        </div>
        <div class="firefly-calendar-grid" aria-label={`${calendarMonthName} ${calendarYear} blog upload calendar`}>
          {Array.from({ length: firstDayOffset }).map(() => (
            <span class="firefly-calendar-blank" aria-hidden="true"></span>
          ))}
          {calendarDays.map((day) => (
            <span
              class={`firefly-calendar-day heat-${day.heat}${day.count > 0 ? ' has-posts' : ''}`}
              title={`${day.count} post${day.count === 1 ? '' : 's'} on ${calendarMonthName} ${day.day}`}
            >
              {day.day}
            </span>
          ))}
        </div>
      </section>
    </aside>
  </main>

  <BackToTop />

  <div id="copyright">
    <ul><li>&copy; Caiwei Wang</li><li>Blog archive</li></ul>
  </div>
</SiteLayout>
