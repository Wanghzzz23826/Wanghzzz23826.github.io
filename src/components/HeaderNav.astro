---
interface Props {
  active?: 'home' | 'blog';
}

const { active = 'home' } = Astro.props;
const homeHref = (hash: string) => active === 'home' ? hash : `/${hash}`;
---
<header id="header" class="prism-header">
  <a href="/" class="logo">Caiwei Wang</a>
</header>

<nav id="nav" class="prism-nav">
  <ul class="links">
    <li class={active === 'home' ? 'active' : undefined}><a href={homeHref('#about')}>About</a></li>
    <li><a href={homeHref('#research')}>Research</a></li>
    <li><a href={homeHref('#publications')}>Publications</a></li>
    <li><a href={homeHref('#awards')}>Awards</a></li>
    <li><a href={homeHref('#skills')}>Skills</a></li>
    <li class={active === 'blog' ? 'active' : undefined}><a href="/blog/">Blog</a></li>
  </ul>
  <ul class="icons">
    <li><a href="mailto:wanghz23826@email.com" class="icon solid fa-envelope"><span class="label">Email</span></a></li>
    <li><a href="https://github.com/" class="icon brands fa-github"><span class="label">GitHub</span></a></li>
  </ul>
</nav>
